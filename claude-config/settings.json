{
  "env": {
    "DISABLE_TELEMETRY": "1",
    "CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC": "1"
  },
  "permissions": {
    "allow": [
      "mcp__pencil"
    ],
    "defaultMode": "acceptEdits",
    "allowedCommands": [
      "git",
      "npm",
      "yarn",
      "pnpm"
    ],
    "blockedCommands": [
      "rm",
      "sudo",
      "chmod 777"
    ],
    "allowedDirectories": [
      "./src",
      "./tests",
      "./docs"
    ],
    "blockedDirectories": [
      "./node_modules",
      "./.env"
    ],
    "requireConfirmation": [
      "git push",
      "npm publish"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Claude needs attention\" with title \"Claude Code\" sound name \"Ping\"'"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "git status > /tmp/claude-git-context.txt && echo 'Development context loaded'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Job'\\''s not finished.\" with title \"JOB FINISHED?\"' && afplay ~/.claude/green-giant.mp3"
          }
        ]
      }
    ],
    "PreToolUse": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/cc-statusline-rs"
  },
  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "swift-lsp@claude-plugins-official": true,
    "slack@claude-plugins-official": true
  },
  "autoUpdatesChannel": "stable",
  "minimumVersion": "2.1.15",
  "mcpServers": {
    "notion": {
      "type": "sse",
      "url": "https://mcp.notion.com/sse"
    },
    "figma-desktop": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp"
    },
    "jira": {
      "type": "http",
      "url": "https://mcp.atlassian.com/v1/mcp"
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp"
    }
  },
  "github": {
    "type": "stdio",
    "command": "gh",
    "args": [
      "mcp"
    ]
  },
  "skipDangerousModePermissionPrompt": true
}
